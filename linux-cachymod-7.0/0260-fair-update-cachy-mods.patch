2.47.1

Improve prefer-idle-core and sched-idle policy

  This patch improves the CachyMod 6.18 0280 patch
  0280-prefer-prevcpu-for-wakeup.patch (included in CachyOS 7.0)
  https://github.com/CachyOS/linux/commit/376f0e652af46c

diff -uarp a/kernel/sched/fair.c b/kernel/sched/fair.c
--- a/kernel/sched/fair.c
+++ b/kernel/sched/fair.c
@@ -1460,8 +1460,6 @@ static inline bool is_core_idle(int cpu)
 	int sibling;
 
 	for_each_cpu(sibling, cpu_smt_mask(cpu)) {
-		if (cpu == sibling)
-			continue;
 
 		if (!idle_cpu(sibling))
 			return false;
@@ -10436,7 +10434,7 @@ static bool sched_use_asym_prio(struct s
 	if (!sched_smt_active())
 		return true;
 
-	return sd->flags & SD_SHARE_CPUCAPACITY || is_idle_core(cpu);
+	return sd->flags & SD_SHARE_CPUCAPACITY || is_core_idle(cpu);
 }
 
 static inline bool sched_asym(struct sched_domain *sd, int dst_cpu, int src_cpu)
